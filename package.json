    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.9.1",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
